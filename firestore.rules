rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 유저 문서: 본인만 읽기/쓰기
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // 몬스터별 학습 진행 상황: 본인만 읽기/쓰기
      match /progress/{monsterId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // EXP 이벤트 로그: append-only (생성만 허용)
      match /expEvents/{eventId} {
        allow read:   if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid;
        // update, delete 불허 (무결성 보호)
      }
    }

    // 게임 콘텐츠: 인증된 유저 읽기 전용
    match /monsters/{monsterId} {
      allow read: if request.auth != null;
    }

    match /lessons/{lessonId} {
      allow read: if request.auth != null;
    }

    match /quizQuestions/{questionId} {
      allow read: if request.auth != null;
    }

    match /bossQuestions/{questionId} {
      allow read: if request.auth != null;
    }
  }
}
